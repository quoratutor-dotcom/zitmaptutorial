{
  "name": "zitmap-tutorials-backend",
  "version": "1.0.0",
  "description": "Real Node.js/Express backend API for ZITMAP Tutorials, backed by PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "db:migrate": "node db/migrate.js",
    "test": "node --test --require ./test/env.js test/*.test.js",
    "test:storage": "node --test --require ./test/env.js test/storage.test.js test/storage.local.test.js",
    "test:visual": "node test/visual/run.js",
    "verify:reset-demo": "node scripts/verify-password-reset-demo.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "mailparser": "^3.9.12",
    "puppeteer-core": "^25.3.0",
    "s3rver": "^3.7.1",
    "smtp-server": "^3.19.1",
    "supertest": "^7.2.2"
  }
}
